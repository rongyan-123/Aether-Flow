generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Player {
  id        String   @id @default(cuid())
  status    String   @default("ALIVE") // ALIVE | DEAD
  name      String   
  gender    String   
  
  stats          Json
  inventory      Json    @default("[]")
  codex          Json    @default("[]")
  relationships  Json    @default("{}")
  situations     Json    @default("[]")
  foreshadowings Json    @default("[]") 
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chatHistory          ChatMessage[]
  conversationSummaries ConversationSummary[]
}

model ChatMessage {
  id        String   @id @default(cuid())
  role      String   
  content   String   @db.Text
  thinking  String?  @db.Text 
  
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id])
  
  createdAt DateTime @default(now())
}

model ConversationSummary {
  id          String   @id @default(cuid())
  playerId    String
  content     String   @db.Text
  fromIndex   Int      @default(0)
  toIndex     Int      @default(0)
  createdAt   DateTime @default(now())

  player      Player   @relation(fields: [playerId], references: [id])
}

model ConversationVector {
  id              Int      @id @default(autoincrement())
  conversationId  String   @map("conversation_id")
  content         String   @db.Text
  metadata        Json     @default("{}")

  @@index([conversationId])
  @@map("conversation_vectors")
}
